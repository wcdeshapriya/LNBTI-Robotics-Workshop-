/* This Arduino program demonstrates a simple LED blinking operation using digital pin 3
The setup() function configures pin 3 as an output,
while the loop() function continuously turns the LED ON and OFF with a 1-second delay, 
creating a blinking effect.
*/

void setup() { 
		pinMode(3, OUTPUT);
		}

void loop() {
	 digitalWrite(3, HIGH); 
	 delay(1000); 

	 digitalWrite(3, LOW);
	 delay(1000); 
	}



